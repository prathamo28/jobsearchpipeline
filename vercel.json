{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=60, stale-while-revalidate=300" }] },
    { "source": "/config.js", "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] }
  ]
}
